<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane stylesheets="@fogliodistile.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mailapp.demo.Controllers.ServerController">
   <children>
      <AnchorPane maxHeight="900.0" maxWidth="900.0" minHeight="0.0" minWidth="0.0" prefHeight="395.0" prefWidth="595.0">
         <children>
            <TextArea fx:id="testolog" editable="false" layoutX="1.0" layoutY="75.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="60.0">
               <font>
                  <Font size="18.0" />
               </font>
            </TextArea>
            <Button fx:id="startServer" layoutX="14.0" layoutY="14.0" maxHeight="900.0" maxWidth="900.0" mnemonicParsing="false" onMouseClicked="#onStartServerClick" prefHeight="33.0" prefWidth="109.0" text="Start Server" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="10.0" />
            <Button fx:id="stopServer" layoutX="136.0" layoutY="10.0" maxHeight="900.0" maxWidth="900.0" mnemonicParsing="false" onMouseClicked="#onStopServerClick" prefHeight="33.0" prefWidth="109.0" text="Stop Server" AnchorPane.leftAnchor="135.0" AnchorPane.topAnchor="10.0" />
         </children>
      </AnchorPane>
   </children>
</Pane>
